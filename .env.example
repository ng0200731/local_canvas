# ──────────────────────────────────────────────────────────────────────────
# Infinite Canvas AI Agent — environment variables
#
# Copy this file to `.env.local` and fill in what you need.
# ALL KEYS ARE OPTIONAL: the app runs in local/demo mode with zero config.
# Add a key to switch that capability on (cloud persistence, auth, AI generation).
# ──────────────────────────────────────────────────────────────────────────

# ── Supabase (optional — enables cloud auth, Postgres persistence, Storage) ──
# Create a project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Preferred for new Supabase projects. The legacy ANON_KEY name remains supported.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY. Never expose to the client or prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ── Xiangsu AI (optional — enables AI image generation) ──
# Server-only. Rotate any key that has been shared publicly before using it.
XIANGSU_API_KEY=

# SMTP email delivery (optional, server-only)
# Optional local SMTP-catcher override for Mailpit/MailHog. Leave blank to send
# from local development through 163.com first, with Gmail as the fallback.
SMTP_LOCAL_HOST=
SMTP_LOCAL_PORT=
SMTP_LOCAL_SECURE=false
SMTP_LOCAL_USERNAME=
SMTP_LOCAL_PASSWORD=
# 163.com is the primary remote provider. Use the SMTP authorization password,
# not the normal account password.
SMTP_163_USERNAME=
SMTP_163_PASSWORD=
# Gmail is used as a fallback. Use a Google App Password, not the account password.
SMTP_GMAIL_USERNAME=
SMTP_GMAIL_PASSWORD=
# Optional sender display name. The sender address is always the active SMTP username.
SMTP_FROM_NAME=Infinite Canvas

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
